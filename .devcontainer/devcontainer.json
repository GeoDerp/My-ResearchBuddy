{
  "name": "My Research Agent (UBI10)",

  // Build context is the workspace root so COPY pyproject.toml works.
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "USERNAME": "developer",
      "USER_UID": "1000",
      "USER_GID": "1000"
    }
  },

  // Drop all Linux capabilities; add back only what dev work needs.
  // no-new-privileges prevents SUID binaries from escalating at runtime.
  "runArgs": [
    "--cap-drop=ALL",
    "--cap-add=CHOWN",
    "--cap-add=DAC_OVERRIDE",
    "--cap-add=FOWNER",
    "--cap-add=SETUID",
    "--cap-add=SETGID",
    "--cap-add=NET_BIND_SERVICE",
    "--security-opt=no-new-privileges:true",
    "--pids-limit=1024",
    "--ulimit=nofile=1024:1024"
  ],

  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",

  // Run everything as the non-root developer user.
  "remoteUser": "developer",

  "containerEnv": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1",
    "TMOUT": "900",
    "HISTFILE": "/dev/null",
    "HISTSIZE": "0"
  },

  "remoteEnv": {
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "MISTRAL_API_KEY": "${localEnv:MISTRAL_API_KEY}"
  },

  // On first start: create the uv-managed project venv, then run the security audit.
  "postCreateCommand": "cd /workspace && uv sync && security-audit.sh || true",

  "customizations": {
    "vscode": {
      "settings": {
        // Point VS Code at the uv-managed venv created by postCreateCommand.
        "python.defaultInterpreterPath": "/workspace/.venv/bin/python",
        "editor.formatOnSave": true,
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "terminal.integrated.inheritEnv": false,
        "telemetry.telemetryLevel": "off",
        "git.autofetch": false
      },
      "extensions": [
        "ms-python.python",
        "ms-python.pylint",
        "ms-python.flake8",
        "ms-python.mypy-type-checker",
        "ms-python.black-formatter",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml"
      ]
    }
  },

  "features": {}
}
